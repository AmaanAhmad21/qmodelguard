# Backend configuration
# Copy to .env to override (optional; defaults work for local dev).

# Port for uvicorn (default: 8000)
# BACKEND_PORT=8000

# CORS allowed origins (comma-separated)
# Must match where the frontend runs.
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Storage directory for model files (default: backend/app/storage)
# STORAGE_DIR=./app/storage

# JWT secret — REQUIRED in production. Use a strong random value (e.g. openssl rand -base64 32).
# JWT_SECRET=your-secret-key-here

# Optional: encrypt private keys at rest. Set to a Fernet key (python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())").
# If unset, private keys are stored in plaintext in the DB (fine for dev; set in production).
# KEY_ENCRYPTION_KEY=

# Max model upload size in MB (default: 512)
# MAX_MODEL_SIZE_MB=512

# Rate limits (SlowAPI format, e.g. "10/minute", "100/hour"). Tests use high defaults.
# RATE_LIMIT_REGISTER=10/minute
# RATE_LIMIT_LOGIN=10/minute
# RATE_LIMIT_UPLOAD=20/minute
