# Docker Compose environment variables
# Copy to .env and customize before deploying

POSTGRES_USER=qmodelguard
POSTGRES_PASSWORD=changeme
POSTGRES_DB=qmodelguard

# REQUIRED in production — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=dev-secret-change-in-production

# Comma-separated allowed origins for CORS
CORS_ORIGINS=http://localhost,http://localhost:80

# Optional: encrypt private keys at rest (Fernet key, base64url)
# KEY_ENCRYPTION_KEY=
