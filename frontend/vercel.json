{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://REPLACE_WITH_RENDER_BACKEND_URL/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://REPLACE_WITH_RENDER_BACKEND_URL/health"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
